{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "religions-history scripture meta.json",
  "description": "Metadata schema for each downloaded scripture. Every translations/<slug>/meta.json must validate against this.",
  "type": "object",
  "required": [
    "slug",
    "name_zh",
    "name_en",
    "name_original",
    "religion",
    "language",
    "version",
    "version_date",
    "source_platform",
    "source_url",
    "downloaded_at",
    "size_bytes",
    "checksum_sha256",
    "chapter_count",
    "license",
    "verified"
  ],
  "properties": {
    "slug": {"type": "string", "description": "URL-safe identifier, matches translations/<slug>/"},
    "name_zh": {"type": "string"},
    "name_en": {"type": "string"},
    "name_original": {"type": "string", "description": "Title in original language"},
    "religion": {"type": "string", "enum": ["道教", "儒教", "佛教-漢譯", "佛教-巴利", "佛教-梵文", "佛教-藏文", "印度教", "耆那教", "錫克教", "猶太教", "基督教", "伊斯蘭", "巴哈伊", "瑣羅亞斯德", "神道", "兩河", "古埃及", "古希臘羅馬", "北歐", "凱爾特", "斯拉夫", "赫爾墨斯", "諾斯底", "非洲", "瑪雅", "阿茲特克", "印加", "現代新興"]},
    "language": {"type": "string", "description": "e.g. 古典漢語, 梵文, 巴利, 古希臘, 希伯來, 古典阿拉伯, 阿維斯塔"},
    "version": {"type": "string", "description": "Manuscript / edition name, e.g. 王弼本, Schøyen MS, KJV"},
    "version_date": {"type": "string", "description": "Year or century, e.g. '3 世紀', 'c. 200 BCE'"},
    "source_platform": {"type": "string", "description": "e.g. ctext.org, CBETA, GRETIL, Sefaria"},
    "source_url": {"type": "string", "format": "uri"},
    "downloaded_at": {"type": "string", "format": "date-time"},
    "size_bytes": {"type": "integer", "minimum": 1},
    "checksum_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "chapter_count": {"type": "integer", "minimum": 1, "description": "Number of chapters / passages / suttas detected in original.txt"},
    "expected_chapter_count": {"type": ["integer", "null"], "description": "Expected by canonical reference; verify.py compares chapter_count against this"},
    "expected_size_min": {"type": ["integer", "null"]},
    "expected_size_max": {"type": ["integer", "null"]},
    "license": {"type": "string", "description": "e.g. CC BY-SA 4.0, public domain, academic-use-only"},
    "verified": {"type": "boolean", "description": "true after verify.py PASS"},
    "tier": {"type": "string", "enum": ["核心", "次要", "總集"], "description": "Per per-religion-scriptures.md"},
    "notes": {"type": ["string", "null"]}
  }
}
